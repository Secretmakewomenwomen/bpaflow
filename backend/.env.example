# Example only; replace host/user/password/database for your environment.
POSTGRES_DATABASE_URL=postgresql://postgres:123456@localhost:5432/postgres
OSS_REGION=
OSS_BUCKET=
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_PUBLIC_BASE_URL=
ARK_BASE_URL=
ARK_API_KEY=
ARK_EMBEDDING_ENDPOINT_ID=
ARK_MULTIMODAL_EMBEDDING_ENDPOINT_ID=
DOUBAO_EMBEDDING_BASE_URL=
DOUBAO_EMBEDDING_API_KEY=
DOUBAO_EMBEDDING_MODEL=
DOUBAO_EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=16
EMBEDDING_REQUEST_TIMEOUT_SECONDS=30
EMBEDDING_MAX_RETRIES=2
EMBEDDING_RETRY_BACKOFF_SECONDS=0.5
PGVECTOR_TEXT_TABLE=uploaded_file_text_vector
PGVECTOR_IMAGE_TABLE=uploaded_file_image_vector
PGVECTOR_TEXT_VECTOR_DIMENSION=1024
PGVECTOR_IMAGE_VECTOR_DIMENSION=1024
PGVECTOR_DISTANCE_OPERATOR=vector_cosine_ops
PGVECTOR_HNSW_M=16
PGVECTOR_HNSW_EF_CONSTRUCTION=200
SMALL_CHUNK_SIZE=700
SMALL_CHUNK_OVERLAP=120
LARGE_CHUNK_SIZE=2100
OCR_LANGUAGE=chi_sim+eng

# Assistant multi-retrieval
ASSISTANT_ENABLE_BM25=true
ASSISTANT_ENABLE_RULE_RETRIEVAL=true
ASSISTANT_MIN_SIMILARITY_SCORE=0.45
ASSISTANT_MIN_FINAL_SCORE=0.25
ASSISTANT_VECTOR_RETRIEVAL_TOP_K=18
ASSISTANT_BM25_RETRIEVAL_TOP_K=18
ASSISTANT_RULE_RETRIEVAL_TOP_K=12
ASSISTANT_RULE_CHUNKS_PER_FILE=2
ASSISTANT_VECTOR_WEIGHT=0.45
ASSISTANT_BM25_WEIGHT=0.40
ASSISTANT_RULE_WEIGHT=0.15
ASSISTANT_BONUS_FILE_NAME_EXACT=0.12
ASSISTANT_BONUS_TERM_HIT=0.08
ASSISTANT_BONUS_RECENT=0.05
ASSISTANT_BONUS_TYPE_MATCH=0.05
ASSISTANT_RECENT_WINDOW_DAYS=7
